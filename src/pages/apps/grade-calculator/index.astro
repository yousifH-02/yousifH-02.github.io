---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Grade Calculator | Yousif Husni</title>
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Arial, Helvetica, sans-serif;
        background: #0b1020;
        color: #f8fafc;
      }

      .page {
        max-width: 900px;
        margin: 0 auto;
        padding: 32px 18px;
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding: 14px 16px;
        border: 1px solid #26324a;
        border-radius: 16px;
        background: #111827;
      }

      .nav h1 {
        margin: 0;
        font-size: 18px;
      }

      .nav a {
        color: #93c5fd;
        text-decoration: none;
        font-size: 14px;
      }

      .hero {
        margin-top: 18px;
        padding: 28px;
        border: 1px solid #26324a;
        border-radius: 24px;
        background: linear-gradient(135deg, #111827, #172554);
      }

      .hero h2 {
        margin: 0 0 12px;
        font-size: 44px;
        line-height: 1;
      }

      .hero p {
        margin: 0;
        color: #cbd5e1;
        line-height: 1.6;
        max-width: 700px;
      }

      .calculator {
        margin-top: 18px;
        padding: 22px;
        border: 1px solid #26324a;
        border-radius: 24px;
        background: #111827;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }

      label {
        display: block;
        margin-bottom: 8px;
        color: #cbd5e1;
        font-size: 14px;
        font-weight: 700;
      }

      input {
        width: 100%;
        padding: 13px 14px;
        border: 1px solid #334155;
        border-radius: 14px;
        background: #020617;
        color: #f8fafc;
        font-size: 16px;
        outline: none;
      }

      input:focus {
        border-color: #60a5fa;
      }

      .actions {
        margin-top: 18px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      button {
        border: 0;
        border-radius: 999px;
        padding: 12px 18px;
        background: #2563eb;
        color: white;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
      }

      button:hover {
        background: #1d4ed8;
      }

      .reset {
        background: #334155;
      }

      .reset:hover {
        background: #475569;
      }

      .result {
        margin-top: 18px;
        padding: 18px;
        border: 1px solid #334155;
        border-radius: 18px;
        background: #020617;
        color: #f8fafc;
        line-height: 1.6;
      }

      .result strong {
        color: #93c5fd;
      }

      .note {
        margin: 14px 0 0;
        color: #94a3b8;
        font-size: 13px;
        line-height: 1.5;
      }

      @media (max-width: 760px) {
        .grid {
          grid-template-columns: 1fr;
        }

        .hero h2 {
          font-size: 34px;
        }
      }
    </style>
  </head>

  <body>
    <main class="page">
      <header class="nav">
        <h1>Student Grade Calculator</h1>
        <a href="/apps/">← Back to Apps</a>
      </header>

      <section class="hero">
        <h2>Calculate what you need on the final.</h2>
        <p>
          Enter your current grade, how much the final exam is worth, and your goal grade.
          The calculator will estimate the final exam score you need.
        </p>
      </section>

      <section class="calculator">
        <div class="grid">
          <div>
            <label for="currentGrade">Current grade before final (%)</label>
            <input id="currentGrade" type="number" placeholder="Example: 86" />
          </div>

          <div>
            <label for="finalWeight">Final exam weight (%)</label>
            <input id="finalWeight" type="number" placeholder="Example: 25" />
          </div>

          <div>
            <label for="goalGrade">Goal course grade (%)</label>
            <input id="goalGrade" type="number" placeholder="Example: 90" />
          </div>
        </div>

        <div class="actions">
          <button id="calculateBtn" type="button">Calculate</button>
          <button id="resetBtn" class="reset" type="button">Reset</button>
        </div>

        <div id="result" class="result">
          Your result will show here.
        </div>

        <p class="note">
          Formula: needed final score = (goal grade - current grade × non-final weight) ÷ final exam weight.
        </p>
      </section>
    </main>

    <script is:inline>
      const currentGradeInput = document.querySelector("#currentGrade");
      const finalWeightInput = document.querySelector("#finalWeight");
      const goalGradeInput = document.querySelector("#goalGrade");
      const calculateBtn = document.querySelector("#calculateBtn");
      const resetBtn = document.querySelector("#resetBtn");
      const result = document.querySelector("#result");

      if (
        currentGradeInput instanceof HTMLInputElement &&
        finalWeightInput instanceof HTMLInputElement &&
        goalGradeInput instanceof HTMLInputElement &&
        calculateBtn instanceof HTMLButtonElement &&
        resetBtn instanceof HTMLButtonElement &&
        result instanceof HTMLElement
      ) {
        calculateBtn.addEventListener("click", function () {
          const currentGrade = Number(currentGradeInput.value);
          const finalWeight = Number(finalWeightInput.value);
          const goalGrade = Number(goalGradeInput.value);

          if (!currentGradeInput.value || !finalWeightInput.value || !goalGradeInput.value) {
            result.textContent = "Please fill in all three boxes.";
            return;
          }

          if (finalWeight <= 0 || finalWeight > 100) {
            result.textContent = "Final exam weight must be between 1 and 100.";
            return;
          }

          const finalWeightDecimal = finalWeight / 100;
          const nonFinalWeightDecimal = 1 - finalWeightDecimal;
          const neededFinalScore =
            (goalGrade - currentGrade * nonFinalWeightDecimal) / finalWeightDecimal;

          let message = `You need about <strong>${neededFinalScore.toFixed(2)}%</strong> on the final to finish with a <strong>${goalGrade.toFixed(2)}%</strong>.`;

          if (neededFinalScore > 100) {
            message += " This goal may not be possible unless extra credit is available.";
          }

          if (neededFinalScore <= 0) {
            message += " You have already secured this goal even with a very low final score.";
          }

          result.innerHTML = message;
        });

        resetBtn.addEventListener("click", function () {
          currentGradeInput.value = "";
          finalWeightInput.value = "";
          goalGradeInput.value = "";
          result.textContent = "Your result will show here.";
        });
      }
    </script>
  </body>
</html>
