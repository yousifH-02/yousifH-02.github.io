---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cybersecurity Phishing Detector | Yousif Husni</title>
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Arial, Helvetica, sans-serif;
        color: #f8fafc;
        background:
          radial-gradient(circle at top left, rgba(34, 211, 238, 0.16), transparent 30%),
          radial-gradient(circle at top right, rgba(168, 85, 247, 0.16), transparent 30%),
          linear-gradient(135deg, #020617, #0f172a 55%, #111827);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        max-width: 1120px;
        margin: 0 auto;
        padding: 28px 18px 60px;
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border: 1px solid rgba(148, 163, 184, 0.25);
        border-radius: 20px;
        background: rgba(15, 23, 42, 0.82);
      }

      .nav h1 {
        margin: 0;
        font-size: 18px;
      }

      .back {
        color: #22d3ee;
        font-size: 14px;
      }

      .hero {
        margin-top: 16px;
        padding: 30px;
        border: 1px solid rgba(148, 163, 184, 0.25);
        border-radius: 28px;
        background:
          radial-gradient(circle at top right, rgba(34, 211, 238, 0.18), transparent 35%),
          rgba(15, 23, 42, 0.82);
      }

      .eyebrow {
        margin: 0 0 10px;
        color: #22d3ee;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .hero h2 {
        margin: 0 0 12px;
        font-size: clamp(38px, 7vw, 68px);
        line-height: 0.95;
        letter-spacing: -0.05em;
      }

      .hero p {
        margin: 0;
        max-width: 760px;
        color: #a7b3c7;
        line-height: 1.7;
      }

      .grid {
        margin-top: 16px;
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 16px;
        align-items: start;
      }

      @media (max-width: 900px) {
        .grid {
          grid-template-columns: 1fr;
        }
      }

      .panel,
      .tips {
        padding: 20px;
        border: 1px solid rgba(148, 163, 184, 0.25);
        border-radius: 24px;
        background: rgba(15, 23, 42, 0.82);
      }

      .title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
      }

      .title h3 {
        margin: 0;
        font-size: 20px;
      }

      .mini {
        color: #94a3b8;
        font-size: 12px;
      }

      label {
        display: block;
        margin: 14px 0 7px;
        color: #dbeafe;
        font-weight: 800;
        font-size: 13px;
      }

      input,
      textarea {
        width: 100%;
        border: 1px solid rgba(148, 163, 184, 0.32);
        border-radius: 16px;
        padding: 13px 14px;
        background: rgba(2, 6, 23, 0.72);
        color: #f8fafc;
        font: inherit;
        outline: none;
      }

      textarea {
        min-height: 220px;
        resize: vertical;
        line-height: 1.55;
      }

      input:focus,
      textarea:focus {
        border-color: rgba(34, 211, 238, 0.75);
        box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.08);
      }

      .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 16px;
      }

      button {
        border: 0;
        border-radius: 999px;
        padding: 12px 15px;
        color: white;
        font: inherit;
        font-weight: 800;
        cursor: pointer;
        background: linear-gradient(135deg, #0891b2, #7c3aed);
      }

      .secondary {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.14);
      }

      .danger {
        background: rgba(251, 113, 133, 0.16);
        border: 1px solid rgba(251, 113, 133, 0.3);
      }

      .score-wrap {
        display: grid;
        grid-template-columns: 150px 1fr;
        gap: 16px;
        align-items: center;
      }

      @media (max-width: 560px) {
        .score-wrap {
          grid-template-columns: 1fr;
        }
      }

      .score-ring {
        width: 150px;
        height: 150px;
        border-radius: 999px;
        display: grid;
        place-items: center;
        background: conic-gradient(#34d399 0deg, rgba(255, 255, 255, 0.08) 0deg);
        position: relative;
      }

      .score-ring::before {
        content: "";
        position: absolute;
        inset: 10px;
        border-radius: 999px;
        background: #07111f;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .score-text {
        position: relative;
        text-align: center;
      }

      .score-text strong {
        display: block;
        font-size: 38px;
        line-height: 1;
      }

      .score-text span,
      .stat span {
        color: #94a3b8;
        font-size: 12px;
      }

      .risk-pill {
        display: inline-flex;
        width: fit-content;
        border-radius: 999px;
        padding: 8px 11px;
        font-weight: 900;
        font-size: 13px;
        color: #34d399;
        border: 1px solid rgba(52, 211, 153, 0.35);
        background: rgba(52, 211, 153, 0.12);
      }

      .summary,
      .finding p,
      .tip p {
        color: #a7b3c7;
        line-height: 1.55;
      }

      .stats,
      .tip-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-top: 16px;
      }

      @media (max-width: 760px) {
        .stats,
        .tip-grid {
          grid-template-columns: 1fr;
        }
      }

      .stat,
      .finding,
      .tip {
        padding: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.045);
      }

      .stat strong {
        display: block;
        font-size: 20px;
      }

      .findings {
        display: grid;
        gap: 10px;
        margin-top: 16px;
      }

      .finding-title {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 6px;
        font-weight: 900;
      }

      .finding-title span {
        color: #94a3b8;
        font-size: 12px;
        white-space: nowrap;
      }

      .tips {
        margin-top: 16px;
      }

      .tip strong {
        display: block;
        margin-bottom: 7px;
      }
    </style>
  </head>

  <body>
    <main class="page">
      <header class="nav">
        <h1>🛡️ Cybersecurity Phishing Detector</h1>
        <a class="back" href="/apps/">← Back to Apps</a>
      </header>

      <section class="hero">
        <p class="eyebrow">Security Awareness Lab</p>
        <h2>Scan suspicious messages before you click.</h2>
        <p>
          Paste an email, text, or direct message. This tool checks for phishing red flags like urgent language,
          credential requests, payment pressure, suspicious links, fake sender patterns, and risky attachments.
        </p>
      </section>

      <section class="grid">
        <div class="panel">
          <div class="title">
            <h3>Message Scanner</h3>
            <span class="mini">Paste suspicious content below</span>
          </div>

          <label for="senderInput">Sender email or phone number</label>
          <input id="senderInput" type="text" placeholder="Example: support@paypaI-security.com" />

          <label for="subjectInput">Subject or headline</label>
          <input id="subjectInput" type="text" placeholder="Example: Urgent account verification required" />

          <label for="messageInput">Email, text, or DM content</label>
          <textarea id="messageInput" placeholder="Paste the suspicious message here..."></textarea>

          <div class="buttons">
            <button id="scanBtn" type="button">Analyze Message</button>
            <button id="sampleBtn" class="secondary" type="button">Load Sample</button>
            <button id="copyBtn" class="secondary" type="button">Copy Report</button>
            <button id="resetBtn" class="danger" type="button">Reset</button>
          </div>
        </div>

        <div class="panel">
          <div class="title">
            <h3>Threat Report</h3>
            <span class="mini" id="lastScan">Not scanned yet</span>
          </div>

          <div class="score-wrap">
            <div class="score-ring" id="scoreRing">
              <div class="score-text">
                <strong id="scoreNumber">0</strong>
                <span>risk score</span>
              </div>
            </div>

            <div>
              <div class="risk-pill" id="riskPill">Low Risk</div>
              <p class="summary" id="summaryText">
                Add a message and click Analyze Message. The detector will explain what looks safe or suspicious.
              </p>
            </div>
          </div>

          <div class="stats">
            <div class="stat">
              <strong id="linkCount">0</strong>
              <span>links found</span>
            </div>
            <div class="stat">
              <strong id="flagCount">0</strong>
              <span>red flags</span>
            </div>
            <div class="stat">
              <strong id="wordCount">0</strong>
              <span>words checked</span>
            </div>
          </div>

          <div class="findings" id="findingsList">
            <div class="finding">
              <div class="finding-title">No scan yet <span>Info</span></div>
              <p>Your findings will appear here after the message is analyzed.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="tips">
        <div class="title">
          <h3>Quick Safety Rules</h3>
          <span class="mini">Use these before clicking anything</span>
        </div>

        <div class="tip-grid">
          <div class="tip">
            <strong>Verify the sender</strong>
            <p>Check the exact domain and watch for lookalike letters, misspellings, or strange addresses.</p>
          </div>
          <div class="tip">
            <strong>Do not rush</strong>
            <p>Phishing messages often create panic with fake deadlines, locked accounts, invoices, or prizes.</p>
          </div>
          <div class="tip">
            <strong>Go directly</strong>
            <p>Do not use the message link. Open the company website yourself through official channels.</p>
          </div>
        </div>
      </section>
    </main>

    <script is:inline>
      window.addEventListener("DOMContentLoaded", function () {
        const senderInput = document.getElementById("senderInput");
        const subjectInput = document.getElementById("subjectInput");
        const messageInput = document.getElementById("messageInput");
        const scanBtn = document.getElementById("scanBtn");
        const sampleBtn = document.getElementById("sampleBtn");
        const copyBtn = document.getElementById("copyBtn");
        const resetBtn = document.getElementById("resetBtn");
        const scoreRing = document.getElementById("scoreRing");
        const scoreNumber = document.getElementById("scoreNumber");
        const riskPill = document.getElementById("riskPill");
        const summaryText = document.getElementById("summaryText");
        const linkCount = document.getElementById("linkCount");
        const flagCount = document.getElementById("flagCount");
        const wordCount = document.getElementById("wordCount");
        const findingsList = document.getElementById("findingsList");
        const lastScan = document.getElementById("lastScan");

        let latestReport = "No scan has been run yet.";

        function addFinding(findings, title, severity, points, detail) {
          findings.push({ title, severity, points, detail });
        }

        function getUrls(text) {
          const matches = text.match(/https?:\/\/[^\s)]+|www\.[^\s)]+/gi);
          return matches ? matches : [];
        }

        function getRiskColor(score) {
          if (score >= 75) return "#fb7185";
          if (score >= 45) return "#facc15";
          if (score >= 20) return "#22d3ee";
          return "#34d399";
        }

        function getRiskLabel(score) {
          if (score >= 75) return "High Risk";
          if (score >= 45) return "Medium Risk";
          if (score >= 20) return "Low to Medium Risk";
          return "Low Risk";
        }

        function setRiskStyles(score) {
          const color = getRiskColor(score);
          const degrees = Math.min(score, 100) * 3.6;
          scoreRing.style.background =
            "conic-gradient(" +
            color +
            " " +
            degrees +
            "deg, rgba(255,255,255,.08) " +
            degrees +
            "deg)";
          riskPill.textContent = getRiskLabel(score);
          riskPill.style.color = color;
          riskPill.style.borderColor = color;
        }

        function renderFindings(findings) {
          findingsList.innerHTML = "";

          if (findings.length === 0) {
            findingsList.innerHTML =
              '<div class="finding"><div class="finding-title">No major red flags found <span>Good</span></div><p>This message does not show obvious phishing patterns. Still verify links and sender identity before taking action.</p></div>';
            return;
          }

          findings.forEach(function (finding) {
            const card = document.createElement("div");
            card.className = "finding";
            card.innerHTML =
              '<div class="finding-title">' +
              finding.title +
              "<span>" +
              finding.severity +
              " +" +
              finding.points +
              "</span></div><p>" +
              finding.detail +
              "</p>";
            findingsList.appendChild(card);
          });
        }

        function analyzeMessage() {
          const sender = senderInput.value.trim();
          const subject = subjectInput.value.trim();
          const message = messageInput.value.trim();
          const combined = (sender + " " + subject + " " + message).toLowerCase();
          const urls = getUrls(combined);
          const words = message ? message.split(/\s+/).filter(Boolean).length : 0;
          const findings = [];
          let score = 0;

          if (!sender && !subject && !message) {
            summaryText.textContent = "Paste a suspicious message first so the detector has something to analyze.";
            return;
          }

          const checks = [
            {
              terms: ["urgent", "immediately", "act now", "final warning", "expires", "suspended", "locked", "verify now"],
              title: "Urgency pressure detected",
              severity: "Medium",
              points: 8,
              detail: "The message uses time pressure or fear. Phishing often tries to rush you before you think.",
            },
            {
              terms: ["password", "login", "sign in", "verify your account", "confirm your account", "security code", "2fa", "ssn"],
              title: "Credential request detected",
              severity: "High",
              points: 10,
              detail: "The message asks about login, password, account verification, or sensitive identity details.",
            },
            {
              terms: ["wire transfer", "gift card", "invoice", "refund", "payment failed", "bank account", "crypto", "bitcoin", "prize", "winner"],
              title: "Money or payment pressure detected",
              severity: "High",
              points: 10,
              detail: "The message references payment, invoices, refunds, prizes, gift cards, or financial action.",
            },
            {
              terms: ["attachment", ".zip", ".exe", ".scr", ".bat", "macro", "enable content"],
              title: "Risky attachment language detected",
              severity: "High",
              points: 12,
              detail: "Unexpected attachments, executable files, or macro instructions are common malware delivery methods.",
            },
          ];

          checks.forEach(function (check) {
            check.terms.forEach(function (term) {
              if (combined.includes(term)) {
                score += check.points;
                addFinding(findings, check.title, check.severity, check.points, check.detail);
              }
            });
          });

          urls.forEach(function (url) {
            score += 6;
            addFinding(
              findings,
              "Link found",
              "Low",
              6,
              "A link is included. Hover over it, inspect the domain, and avoid clicking from the message directly."
            );

            if (["bit.ly", "tinyurl", "t.co", "goo.gl", "ow.ly", "is.gd", "buff.ly"].some((shortener) => url.includes(shortener))) {
              score += 12;
              addFinding(findings, "Shortened URL detected", "High", 12, "Shortened links hide the real destination, which increases phishing risk.");
            }

            if ([".ru", ".cn", ".tk", ".zip", ".mov", ".top", ".xyz"].some((tld) => url.includes(tld))) {
              score += 9;
              addFinding(findings, "Suspicious domain ending detected", "Medium", 9, "The link uses a domain ending that is often abused in suspicious campaigns.");
            }
          });

          if (sender.toLowerCase().includes("paypai") || sender.toLowerCase().includes("micros0ft") || sender.toLowerCase().includes("arnazon")) {
            score += 18;
            addFinding(findings, "Lookalike brand spelling", "High", 18, "The sender appears to imitate a trusted brand using swapped or misspelled characters.");
          }

          if (combined.includes("dear customer") || combined.includes("dear user") || combined.includes("valued customer")) {
            score += 5;
            addFinding(findings, "Generic greeting", "Low", 5, "Generic greetings can be normal, but phishing messages often avoid using your real name.");
          }

          score = Math.min(score, 100);

          scoreNumber.textContent = String(score);
          linkCount.textContent = String(urls.length);
          flagCount.textContent = String(findings.length);
          wordCount.textContent = String(words);

          setRiskStyles(score);
          renderFindings(findings);

          if (score >= 75) {
            summaryText.textContent = "This message has multiple high-risk phishing indicators. Do not click links, download files, reply, or enter credentials.";
          } else if (score >= 45) {
            summaryText.textContent = "This message has several suspicious signs. Verify it through official channels before taking action.";
          } else if (score >= 20) {
            summaryText.textContent = "This message has some warning signs. Be cautious, especially with links, attachments, and account requests.";
          } else {
            summaryText.textContent = "This message has a low risk score, but you should still verify the sender and avoid clicking unexpected links.";
          }

          lastScan.textContent = "Scanned just now";

          latestReport =
            "Phishing Detector Report\nRisk Score: " +
            score +
            "/100\nRisk Level: " +
            getRiskLabel(score) +
            "\nLinks Found: " +
            urls.length +
            "\nRed Flags: " +
            findings.length +
            "\nWords Checked: " +
            words +
            "\nSummary: " +
            summaryText.textContent;
        }

        scanBtn.addEventListener("click", analyzeMessage);

        sampleBtn.addEventListener("click", function () {
          senderInput.value = "support@paypaI-security.com";
          subjectInput.value = "Urgent: Account locked - verify now";
          messageInput.value =
            "Dear customer, your account has been suspended due to unusual login activity. Click https://bit.ly/secure-login-update immediately to confirm your password and security code. Failure to act now will permanently lock your account.";
          analyzeMessage();
        });

        copyBtn.addEventListener("click", function () {
          navigator.clipboard.writeText(latestReport).then(function () {
            copyBtn.textContent = "Copied Report";
            setTimeout(function () {
              copyBtn.textContent = "Copy Report";
            }, 1400);
          });
        });

        resetBtn.addEventListener("click", function () {
          senderInput.value = "";
          subjectInput.value = "";
          messageInput.value = "";
          scoreNumber.textContent = "0";
          linkCount.textContent = "0";
          flagCount.textContent = "0";
          wordCount.textContent = "0";
          setRiskStyles(0);
          summaryText.textContent = "Add a message and click Analyze Message. The detector will explain what looks safe or suspicious.";
          lastScan.textContent = "Not scanned yet";
          findingsList.innerHTML =
            '<div class="finding"><div class="finding-title">No scan yet <span>Info</span></div><p>Your findings will appear here after the message is analyzed.</p></div>';
        });
      });
    </script>
  </body>
</html>